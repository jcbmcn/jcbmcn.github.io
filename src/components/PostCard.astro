---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'blog'>;
  showTagButtons?: boolean;
}

const { entry, showTagButtons = false } = Astro.props;
const { title, date, tags = [], description } = entry.data;
const slug = entry.id;

// Format as ISO-like date for technical feel
const formattedDate = date
  ? date.toISOString().split('T')[0]
  : null;
---

<a href={`/posts/${slug}/`} class="metric-panel" data-tags={tags.join(',')}>
  <div class="panel-header">
    <span class="panel-status">
      <span class="status-dot"></span> RUNNING
    </span>
    {formattedDate && <time class="panel-date">{formattedDate}</time>}
  </div>

  <div class="panel-body">
    <h3 class="panel-title">{title}</h3>
    {description && <p class="panel-desc">{description}</p>}
  </div>

  <div class="panel-footer">
    <div class="k8s-labels">
      {tags.map((tag) => (
        <span class="k8s-label"><span class="label-key">tag</span>:<span class="label-val">{tag}</span></span>
      ))}
    </div>
  </div>
</a>

<style>
  .metric-panel {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-ink);
    background: var(--color-panel);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-4);
    transition: all 0.15s ease;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  /* Accent top border like a grafana graph */
  .metric-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 2px;
    background: var(--color-border);
    transition: background 0.15s ease;
  }

  .metric-panel:hover {
    border-color: var(--color-accent);
    background: var(--color-surface);
  }

  .metric-panel:hover::before {
    background: var(--color-accent);
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-light);
    margin-bottom: var(--space-3);
  }

  .panel-status {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--color-success);
    font-weight: 500;
  }

  .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-success);
  }

  .panel-body {
    flex-grow: 1;
  }

  .panel-title {
    font-size: var(--text-md);
    font-weight: 500;
    line-height: 1.3;
    margin: 0 0 var(--space-2);
    color: var(--color-ink);
  }

  .panel-desc {
    font-size: var(--text-sm);
    color: var(--color-ink-mid);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .panel-footer {
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px dashed var(--color-border);
  }

  .k8s-labels {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .k8s-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 2px 6px;
    display: inline-flex;
  }

  .label-key { color: var(--color-accent); padding-right: 2px; }
  .label-val { color: var(--color-warning); padding-left: 2px; }
</style>
