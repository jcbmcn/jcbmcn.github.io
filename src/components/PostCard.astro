---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'blog'>;
  featured?: boolean;
  /** Render interactive filter tag buttons below the card (post list page only) */
  showTagButtons?: boolean;
}

const { entry, featured = false, showTagButtons = false } = Astro.props;
const { title, date, tags = [], featuredImage, images } = entry.data;
const image = featuredImage ?? images?.[0] ?? undefined;
const slug = entry.id;

const formattedDate = date
  ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : null;
---

<article
  class:list={['post-entry', { 'post-entry--featured': featured }]}
  data-tags={tags.join(',')}
>
  <a href={`/posts/${slug}/`} class="post-entry__link">
    <div class="post-entry__inner">
      <div class="post-entry__left">
        <h2 class="post-entry__title">{title}</h2>
        {tags.length > 0 && (
          <div class="post-entry__tags" aria-label="Tags">
            {tags.map((tag) => (
              <span class="post-entry__tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
      <div class="post-entry__right">
        {formattedDate && (
          <time class="post-entry__date" datetime={date?.toISOString()}>
            {formattedDate}
          </time>
        )}
        {image && (
          <img
            src={image}
            alt=""
            width="64"
            height="64"
            class="post-entry__thumb"
            loading="lazy"
            decoding="async"
          />
        )}
      </div>
    </div>
  </a>
</article>

<!-- Tag buttons — rendered outside the <a> to avoid nesting interactive elements -->
{showTagButtons && tags.length > 0 && (
  <ul class="post-entry__tag-buttons" aria-label="Filter by tag">
    {tags.map((tag) => (
      <li>
        <button type="button" class="tag-btn" data-tag={tag} aria-pressed="false">
          {tag}
        </button>
      </li>
    ))}
  </ul>
)}

<style>
  /* --- Entry row --- */
  .post-entry {
    position: relative;
    border-bottom: 1px solid var(--color-border-soft);
  }

  .post-entry:first-child {
    border-top: 1px solid var(--color-border-soft);
  }

  /* Amber left-accent appears on hover — positioned outside normal flow */
  .post-entry::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.18s cubic-bezier(0.22, 1, 0.36, 1);
    border-radius: 0 2px 2px 0;
  }

  .post-entry:hover::before {
    transform: scaleY(1);
  }

  /* --- Clickable area --- */
  .post-entry__link {
    display: block;
    padding: var(--space-4) 0 var(--space-3) var(--space-3);
    text-decoration: none;
    color: inherit;
    transition: background-color 0.12s ease;
  }

  .post-entry:hover .post-entry__link {
    background-color: var(--color-accent-tint);
  }

  .post-entry__inner {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    justify-content: space-between;
  }

  .post-entry__left {
    flex: 1;
    min-width: 0;
  }

  .post-entry__right {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
    padding-right: var(--space-1);
  }

  /* --- Title --- */
  .post-entry__title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-1);
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Featured variant: larger title */
  .post-entry--featured .post-entry__title {
    font-size: var(--text-lg);
  }

  /* --- Date --- */
  .post-entry__date {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-light);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  /* --- Thumbnail --- */
  .post-entry__thumb {
    width: 52px;
    height: 52px;
    object-fit: cover;
    border-radius: 2px;
    opacity: 0.85;
    transition: opacity 0.12s ease;
  }

  .post-entry:hover .post-entry__thumb {
    opacity: 1;
  }

  /* --- Inline tag pills (display only, not interactive) --- */
  .post-entry__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .post-entry__tag {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-ink-light);
    background: none;
    padding: 0;
    line-height: 1.6;
  }

  .post-entry__tag + .post-entry__tag::before {
    content: '·';
    margin-right: 0.25rem;
    color: var(--color-border);
  }

  /* --- Interactive tag buttons (outside the <a>) --- */
  .post-entry__tag-buttons {
    list-style: none;
    margin: 0;
    padding: 0 0 var(--space-3) var(--space-3);
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .post-entry__tag-buttons li {
    display: contents;
  }

  .tag-btn {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: none;
    color: var(--color-accent-text);
    background: var(--color-accent-tint);
    border: 1px solid oklch(66% 0.160 62 / 0.35);
    padding: 0.125rem 0.5rem;
    border-radius: 2px;
    cursor: pointer;
    font-family: var(--font-body);
    line-height: 1.6;
    transition: background-color 0.1s ease, color 0.1s ease;
  }

  .tag-btn:hover {
    background: oklch(66% 0.160 62 / 0.18);
    color: var(--color-accent-hover);
  }

  .tag-btn--active,
  .tag-btn[aria-pressed="true"] {
    background: var(--color-accent);
    color: oklch(99% 0.004 75);
    border-color: var(--color-accent);
  }
</style>
