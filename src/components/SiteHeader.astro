---
---
<header class="site-header no-rule">
  <a href="/" class="wordmark" aria-label="Jacob McNeilly — home">jcbmcn</a>
  <nav class="header-nav" aria-label="Site navigation">
    <a href="/posts/" class="nav-link">Writing</a>
    <a href="/rss.xml" class="nav-link nav-link--rss" aria-label="RSS feed" title="RSS feed">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <circle cx="6.18" cy="17.82" r="2.18"/>
        <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
      </svg>
      <span class="sr-only">RSS</span>
    </a>
    <button type="button" id="theme-toggle" aria-label="Switch to dark mode">
      <span class="icon-moon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </span>
      <span class="icon-sun" style="display:none" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </span>
    </button>
  </nav>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  const moonIcon = btn?.querySelector('.icon-moon') as HTMLElement | null;
  const sunIcon = btn?.querySelector('.icon-sun') as HTMLElement | null;

  function applyTheme(theme: 'light' | 'dark') {
    document.documentElement.setAttribute('data-theme', theme);
    if (moonIcon && sunIcon) {
      moonIcon.style.display = theme === 'light' ? '' : 'none';
      sunIcon.style.display  = theme === 'dark'  ? '' : 'none';
    }
    if (btn) {
      btn.setAttribute('aria-label',
        theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'
      );
    }
  }

  const current = (document.documentElement.getAttribute('data-theme') ?? 'light') as 'light' | 'dark';
  applyTheme(current);

  btn?.addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    localStorage.setItem('theme', next);
    applyTheme(next);
  });
</script>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    padding: 0 var(--gutter);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border-soft);
    /* Amber accent line at very top — distinctive mark */
    border-top: 3px solid var(--color-accent);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  /* Wordmark: Fraunces, lowercase, amber accent on hover */
  .wordmark {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    font-style: italic;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.12s ease;
  }

  .wordmark:hover {
    color: var(--color-accent-text);
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-ink-mid);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    transition: color 0.12s ease;
    letter-spacing: 0.01em;
  }

  .nav-link:hover {
    color: var(--color-ink);
  }

  .nav-link--rss {
    display: flex;
    align-items: center;
    padding: 0.375rem 0.5rem;
  }

  #theme-toggle {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    color: var(--color-ink-mid);
    transition: color 0.12s ease, background-color 0.12s ease;
  }

  #theme-toggle:hover {
    color: var(--color-ink);
    background-color: var(--color-accent-tint);
  }

  #theme-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>
