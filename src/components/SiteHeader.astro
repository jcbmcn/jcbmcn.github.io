---
---
<header class="site-header">
  <div class="header-inner">
    <div class="logo-area">
      <div class="status-indicator"></div>
      <a href="/" class="wordmark" aria-label="Home">cluster-status://jcbmcn</a>
    </div>
    
    <nav class="header-nav" aria-label="Site navigation">
      <a href="/posts/" class="nav-link">/namespace/writing</a>
      <a href="/rss.xml" class="nav-link nav-link--icon" aria-label="RSS feed" title="RSS feed">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header { 
    position: sticky; 
    top: 0; 
    z-index: 50; 
    background: var(--color-panel); 
    border-bottom: 1px solid var(--color-border); 
  }
  
  .header-inner { 
    max-width: var(--container-wide); 
    margin: 0 auto; 
    padding: 0 var(--gutter); 
    height: 3rem; /* Tighter header */
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
  }
  
  .logo-area {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .status-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-success);
    box-shadow: 0 0 8px var(--color-success);
  }

  .wordmark { 
    font-family: var(--font-mono);
    font-size: var(--text-sm); 
    font-weight: 600; 
    color: var(--color-ink); 
    text-decoration: none; 
    transition: color 0.15s; 
  }
  
  .wordmark:hover { color: var(--color-accent); }
  
  .header-nav { 
    display: flex; 
    align-items: center; 
    gap: var(--space-2); 
  }
  
  .nav-link { 
    font-family: var(--font-mono);
    font-size: var(--text-xs); 
    font-weight: 500; 
    color: var(--color-ink-light); 
    text-decoration: none; 
    padding: 0.25rem 0.5rem; 
    border-radius: 3px; 
    border: 1px solid transparent;
    transition: all 0.15s; 
  }
  
  .nav-link:hover { 
    color: var(--color-ink); 
    background: var(--color-surface); 
    border-color: var(--color-border);
  }
  
  .nav-link--icon { display: flex; align-items: center; }
</style>
