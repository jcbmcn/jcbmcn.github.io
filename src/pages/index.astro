---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const recentPosts = allPosts
  .sort((a, b) => {
    const aDate = a.data.date?.getTime() ?? 0;
    const bDate = b.data.date?.getTime() ?? 0;
    return bDate - aDate;
  })
  .slice(0, 6); // Load 6 for a nice 3x2 grid
---

<BaseLayout title="Node: jcbmcn" description="SRE and software engineer writing about Kubernetes, infrastructure, and building things that work.">
  <main class="dashboard">
    
    <div class="row">
      <section class="panel system-info">
        <div class="panel-header">System Information</div>
        <div class="sys-content">
          <img src="/images/avatar.png" alt="Jacob McNeilly" class="sys-avatar" width="120" height="120" />
          <div class="sys-details">
            <h1 class="sys-title">Jacob McNeilly</h1>
            <ul class="sys-metrics">
              <li><span class="m-key">role</span><span class="m-val">SRE · Kubernetes</span></li>
              <li><span class="m-key">status</span><span class="m-val success">Healthy</span></li>
              <li><span class="m-key">location</span><span class="m-val">Earth-1</span></li>
            </ul>
            <p class="sys-bio">Software engineer focused on reliability engineering, Kubernetes, and the messy reality of running distributed systems in production.</p>
          </div>
        </div>
      </section>

      <section class="panel sys-links">
        <div class="panel-header">Endpoints</div>
        <div class="link-grid">
           <a href="/posts/" class="endpoint">/var/log/writing</a>
           <a href="https://github.com/jcbmcn" target="_blank" class="endpoint">github.com/jcbmcn</a>
           <a href="https://www.linkedin.com/in/jacob-mcneilly-a6a516112/" target="_blank" class="endpoint">linkedin.com/in/jacob</a>
        </div>
      </section>
    </div>

    <section class="panel widget-recent">
      <div class="panel-header split">
        <span>Recent Emits</span>
        <a href="/posts/" class="view-all">Query All →</a>
      </div>
      <div class="posts-grid">
        {recentPosts.map((entry) => (
          <PostCard entry={entry} />
        ))}
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .dashboard { 
    max-width: var(--container-max); 
    margin: 0 auto; 
    padding: var(--space-4) var(--gutter); 
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .row {
    display: grid;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .row { grid-template-columns: 2fr 1fr; }
  }

  .panel {
    background: var(--color-panel);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-4);
  }

  .panel-header {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ink-light);
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
  }
  
  .panel-header.split {
    display: flex; justify-content: space-between; align-items: baseline;
  }

  .sys-content {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
  }

  .sys-avatar {
    width: 120px; height: 120px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .sys-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .sys-metrics {
    list-style: none; padding: 0; margin: 0 0 var(--space-3) 0;
    font-family: var(--font-mono); font-size: var(--text-xs);
    display: flex; flex-direction: column; gap: 4px;
  }

  .m-key { color: var(--color-ink-light); display: inline-block; width: 70px; }
  .m-val { color: var(--color-ink); }
  .m-val.success { color: var(--color-success); }

  .sys-bio {
    font-size: var(--text-sm);
    color: var(--color-ink-mid);
    max-width: 60ch;
  }

  .link-grid {
    display: flex; flex-direction: column; gap: var(--space-2);
  }

  .endpoint {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: var(--space-2);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-accent);
  }

  .endpoint:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-tint);
  }

  .view-all {
    color: var(--color-accent); text-decoration: none; font-size: 10px;
  }

  .posts-grid { 
    display: grid; grid-template-columns: 1fr; gap: var(--space-3); 
  }
  @media (min-width: 768px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .posts-grid { grid-template-columns: repeat(3, 1fr); } }
</style>le>