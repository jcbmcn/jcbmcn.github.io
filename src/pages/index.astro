---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const recentPosts = allPosts
  .sort((a, b) => {
    const aDate = a.data.date?.getTime() ?? 0;
    const bDate = b.data.date?.getTime() ?? 0;
    return bDate - aDate;
  })
  .slice(0, 3);
---

<BaseLayout title="Jacob McNeilly" description="SRE and software engineer writing about Kubernetes, infrastructure, and building things that work.">
  <main class="page-container">
    <!-- Hero -->
    <section class="hero">
      <div class="hero__inner">
        <img
          src="/images/avatar.png"
          alt="Jacob McNeilly"
          width="88"
          height="88"
          class="hero__avatar"
        />
        <div class="hero__content">
          <h1 class="hero__name">Jacob McNeilly</h1>
          <p class="hero__tagline">SRE · Kubernetes · Systems that work</p>
          <nav class="hero__links" aria-label="Social links">
            <a href="https://github.com/jcbmcn" class="hero__link" rel="noopener noreferrer" target="_blank">
              GitHub
            </a>
            <a href="https://www.linkedin.com/in/jacob-mcneilly-a6a516112/" class="hero__link" rel="noopener noreferrer" target="_blank">
              LinkedIn
            </a>
          </nav>
        </div>
      </div>
      <p class="hero__bio">
        I'm a software engineer focused on reliability engineering, Kubernetes, and the messy reality of running distributed systems in production. I write about tools I've built, problems I've debugged, and ideas I haven't figured out yet.
      </p>
    </section>

    <!-- Recent posts -->
    <section class="recent-posts">
      <div class="recent-posts__header">
        <h2 class="recent-posts__heading">Recent Posts</h2>
        <a href="/posts/" class="recent-posts__all-link">All posts →</a>
      </div>
      <div class="recent-posts__list">
        {recentPosts.map((entry) => (
          <PostCard entry={entry} />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .page-container {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  /* Hero */
  .hero {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
  }

  .hero__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .hero__avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
  }

  .hero__name {
    margin: 0 0 0.25rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .hero__tagline {
    margin: 0 0 0.75rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .hero__links {
    display: flex;
    gap: 1rem;
  }

  .hero__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.25rem 0.625rem;
    border: 1px solid var(--color-accent);
    border-radius: 0.375rem;
    transition: background-color 0.15s ease;
  }

  .hero__link:hover {
    background: var(--color-accent-subtle);
    color: var(--color-accent);
  }

  .hero__bio {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 42rem;
  }

  /* Recent posts */
  .recent-posts__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .recent-posts__heading {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .recent-posts__all-link {
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  .recent-posts__all-link:hover {
    text-decoration: underline;
  }

  .recent-posts__list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
</style>
