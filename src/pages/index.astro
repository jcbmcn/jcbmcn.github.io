---
// Placeholder page — Phase 3 replaces this with the real homepage
import { getCollection } from 'astro:content';

// Filter out drafts — verifies INFRA-05
const posts = await getCollection('blog', ({ data }) => data.draft !== true);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Jacob McNeilly</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 600px;
        margin: 4rem auto;
        padding: 0 1.5rem;
        color: #111;
      }
      h1 { margin-bottom: 0.25rem; }
      p { color: #555; margin-top: 0; }
      .links { display: flex; gap: 1rem; margin-top: 1.5rem; }
      .links a { color: #0070f3; text-decoration: none; }
      .links a:hover { text-decoration: underline; }
      .notice {
        margin-top: 2rem;
        padding: 0.75rem 1rem;
        background: #fff8e1;
        border-left: 3px solid #f0a500;
        border-radius: 4px;
        font-size: 0.9rem;
        color: #555;
      }
    </style>
  </head>
  <body>
    <h1>Jacob McNeilly</h1>
    <p>Thoughts on SRE, homelab, and Kubernetes.</p>
    <nav class="links">
      <a href="https://github.com/jcbmcn">GitHub</a>
      <a href="https://www.linkedin.com/in/jacob-mcneilly-a6a516112/">LinkedIn</a>
