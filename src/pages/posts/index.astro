---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const posts = allPosts.sort((a, b) => {
  const aDate = a.data.date?.getTime() ?? 0;
  const bDate = b.data.date?.getTime() ?? 0;
  return bDate - aDate;
});

// Serialize post data for client-side Fuse.js
const postData = posts.map(entry => ({
  id: entry.id,
  title: entry.data.title,
  tags: entry.data.tags ?? [],
  description: entry.data.description ?? '',
}));

// Collect unique tags for filter bar (sorted alphabetically)
const allTags = [...new Set(posts.flatMap(p => p.data.tags ?? []))].sort();
---

<BaseLayout
  title="Writing — Jacob McNeilly"
  description="All posts on SRE, Kubernetes, and software engineering."
>
  <main class="posts-page">
    <!-- Hidden data blob for client-side search -->
    <script type="application/json" id="post-data" set:html={JSON.stringify(postData)} />

    <!-- Page header -->
    <header class="posts-header">
      <h1 class="posts-title">Writing</h1>
      <p class="posts-count" id="posts-count">
        {posts.length} post{posts.length !== 1 ? 's' : ''}
      </p>
    </header>

    <!-- Search + tag controls -->
    <div class="posts-controls">
      <div class="search-wrap">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="search"
          id="search-input"
          class="search-input"
          placeholder="Search posts"
          aria-label="Search posts"
          autocomplete="off"
        />
      </div>
      {allTags.length > 0 && (
        <div class="tag-filter" role="group" aria-label="Filter by tag">
          {allTags.map(tag => (
            <button type="button" class="filter-chip" data-tag={tag} aria-pressed="false">
              {tag}
            </button>
          ))}
          <button
            type="button"
            class="clear-btn"
            id="clear-filters"
            aria-label="Clear all filters"
            hidden
          >
            × clear
          </button>
        </div>
      )}
    </div>

    <!-- Aria live region -->
    <div aria-live="polite" aria-atomic="true" class="sr-only" id="filter-status"></div>

    <!-- Post list -->
    <div class="post-list" id="post-list">
      {posts.map((entry) => (
        <PostCard entry={entry} showTagButtons={true} />
      ))}
    </div>

    <!-- Empty state -->
    <p class="empty-state" id="empty-state" hidden></p>
  </main>

<script>
import Fuse from 'fuse.js';

document.addEventListener('DOMContentLoaded', () => {
  // --- Data ---
  const raw = document.getElementById('post-data')?.textContent ?? '[]';
  const postData: { id: string; title: string; tags: string[]; description: string }[] = JSON.parse(raw);

  const fuse = new Fuse(postData, {
    keys: ['title', 'tags', 'description'],
    ignoreLocation: true,
    threshold: 0.3,
    includeScore: false,
  });

  // --- DOM refs ---
  const searchInput  = document.getElementById('search-input') as HTMLInputElement | null;
  const clearBtn     = document.getElementById('clear-filters') as HTMLButtonElement | null;
  const emptyState   = document.getElementById('empty-state') as HTMLParagraphElement | null;
  const filterStatus = document.getElementById('filter-status') as HTMLDivElement | null;
  const countEl      = document.getElementById('posts-count') as HTMLParagraphElement | null;
  const postEntries  = Array.from(document.querySelectorAll<HTMLElement>('[data-tags]'));
  const filterChips  = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter-chip'));

  // --- State ---
  let activeTags  = new Set<string>();
  let searchQuery = '';

  // --- Core filter ---
  function applyFilters() {
    let searchMatchIds: Set<string> | null = null;
    if (searchQuery.trim() !== '') {
      const results = fuse.search(searchQuery.trim());
      searchMatchIds = new Set(results.map(r => r.item.id));
    }

    let visibleCount = 0;
    postEntries.forEach(entry => {
      const link   = entry.querySelector('a');
      const cardId = link?.getAttribute('href')?.replace(/^\/posts\//, '').replace(/\/$/, '') ?? '';
      const cardTagsRaw = entry.getAttribute('data-tags') ?? '';
      const cardTags    = cardTagsRaw ? cardTagsRaw.split(',') : [];

      const matchesSearch = searchMatchIds === null || searchMatchIds.has(cardId);
      const matchesTags   = activeTags.size === 0 || [...activeTags].every(t => cardTags.includes(t));
      const visible       = matchesSearch && matchesTags;

      entry.style.display = visible ? '' : 'none';

      // Also hide the adjacent tag-button list if present (next sibling)
      const tagButtons = entry.nextElementSibling;
      if (tagButtons?.classList.contains('post-entry__tag-buttons')) {
        (tagButtons as HTMLElement).style.display = visible ? '' : 'none';
      }

      if (visible) visibleCount++;
    });

    // Update count
    if (countEl) {
      countEl.textContent = `${visibleCount} post${visibleCount !== 1 ? 's' : ''}`;
    }

    // Empty state
    if (emptyState) {
      if (visibleCount === 0) {
        const hasSearch = searchQuery.trim() !== '';
        const hasTags   = activeTags.size > 0;
        if (hasSearch && hasTags) {
          emptyState.textContent = `No posts match "${searchQuery.trim()}" with the selected tags.`;
        } else if (hasSearch) {
          emptyState.textContent = `No posts match "${searchQuery.trim()}".`;
        } else if (activeTags.size === 1) {
          emptyState.textContent = `No posts tagged "${[...activeTags][0]}".`;
        } else {
          emptyState.textContent = `No posts match all selected tags.`;
        }
        emptyState.hidden = false;
      } else {
        emptyState.hidden = true;
      }
    }

    // Aria live
    if (filterStatus) {
      filterStatus.textContent = `${visibleCount} post${visibleCount !== 1 ? 's' : ''} shown`;
    }

    // Clear button visibility
    const hasActiveFilters = activeTags.size > 0 || searchQuery.trim() !== '';
    if (clearBtn) clearBtn.hidden = !hasActiveFilters;
  }

  // --- Sync all PostCard tag-button states ---
  function syncTagBtns() {
    document.querySelectorAll<HTMLButtonElement>('.tag-btn[data-tag]').forEach(btn => {
      const tag = btn.getAttribute('data-tag') ?? '';
      const isActive = activeTags.has(tag);
      btn.setAttribute('aria-pressed', String(isActive));
      btn.classList.toggle('tag-btn--active', isActive);
    });
  }

  // --- Sync filter bar chip states ---
  function syncFilterChips() {
    filterChips.forEach(chip => {
      const tag = chip.getAttribute('data-tag') ?? '';
      const isActive = activeTags.has(tag);
      chip.setAttribute('aria-pressed', String(isActive));
      chip.classList.toggle('filter-chip--active', isActive);
    });
  }

  // --- Toggle tag ---
  function toggleTag(tag: string) {
    if (activeTags.has(tag)) {
      activeTags.delete(tag);
    } else {
      activeTags.add(tag);
    }
    syncFilterChips();
    syncTagBtns();
    applyFilters();
  }

  // --- Events ---
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    applyFilters();
  });

  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const tag = chip.getAttribute('data-tag') ?? '';
      if (tag) toggleTag(tag);
    });
  });

  // Delegated click for PostCard tag buttons
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.tag-btn[data-tag]');
    if (btn) {
      const tag = btn.getAttribute('data-tag') ?? '';
      if (tag) toggleTag(tag);
    }
  });

  clearBtn?.addEventListener('click', () => {
    activeTags.clear();
    searchQuery = '';
    if (searchInput) searchInput.value = '';
    syncFilterChips();
    syncTagBtns();
    applyFilters();
  });
});
</script>

<style>
  /* ============================================================
     PAGE LAYOUT
     ============================================================ */
  .posts-page {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--gutter) clamp(4rem, 10vw, 8rem);
  }

  /* ============================================================
     HEADER
     ============================================================ */
  .posts-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: clamp(2rem, 5vw, 3.5rem) 0 var(--space-5);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-4);
  }

  .posts-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    font-style: italic;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
  }

  .posts-count {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-ink-light);
    margin: 0;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }

  /* ============================================================
     SEARCH + FILTER CONTROLS
     ============================================================ */
  .posts-controls {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border-soft);
    margin-bottom: var(--space-2);
  }

  /* Search input with icon */
  .search-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 0.75rem;
    color: var(--color-ink-faint);
    pointer-events: none;
    flex-shrink: 0;
  }

  .search-input {
    width: 100%;
    padding: 0.5rem 0.75rem 0.5rem 2.25rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.12s ease;
  }

  .search-input::placeholder {
    color: var(--color-ink-faint);
  }

  .search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 2px oklch(66% 0.160 62 / 0.15);
  }

  /* Tag filter row */
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
  }

  .filter-chip {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-ink-mid);
    background: transparent;
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.625rem;
    border-radius: 2px;
    cursor: pointer;
    transition: border-color 0.1s ease, background-color 0.1s ease, color 0.1s ease;
    line-height: 1.6;
  }

  .filter-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-text);
  }

  .filter-chip--active,
  .filter-chip[aria-pressed="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: oklch(99% 0.004 75);
  }

  .clear-btn {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--color-ink-light);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.2rem 0.25rem;
    transition: color 0.1s ease;
  }

  .clear-btn:hover {
    color: var(--color-ink);
  }

  /* ============================================================
     POST LIST
     ============================================================ */
  .post-list {
    /* PostCard entries handle their own borders */
  }

  /* ============================================================
     EMPTY STATE
     ============================================================ */
  .empty-state {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-ink-light);
    padding: var(--space-6) 0;
    margin: 0;
  }
</style>
</BaseLayout>
