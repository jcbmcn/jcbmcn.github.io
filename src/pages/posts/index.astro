---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const posts = allPosts.sort((a, b) => {
  const aDate = a.data.date?.getTime() ?? 0;
  const bDate = b.data.date?.getTime() ?? 0;
  return bDate - aDate;
});
---

<BaseLayout title="Posts — Jacob McNeilly" description="All posts on SRE, Kubernetes, and software engineering.">
  <main class="page-container">
    <header class="listing-header">
      <a href="/" class="back-link">← Home</a>
      <h1 class="listing-title">Posts</h1>
      <p class="listing-count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
    </header>

    <div class="post-list">
      {posts.map((entry) => (
        <PostCard entry={entry} />
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .page-container {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .listing-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .listing-title {
    margin: 0 0 0.25rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .listing-count {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
</style>
