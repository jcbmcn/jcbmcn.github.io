---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const posts = allPosts.sort((a, b) => {
  const aDate = a.data.date?.getTime() ?? 0;
  const bDate = b.data.date?.getTime() ?? 0;
  return bDate - aDate;
});

// Serialize post data for client-side Fuse.js
const postData = posts.map(entry => ({
  id: entry.id,
  title: entry.data.title,
  tags: entry.data.tags ?? [],
  description: entry.data.description ?? '',
}));

// Collect unique tags for filter bar (sorted alphabetically)
const allTags = [...new Set(posts.flatMap(p => p.data.tags ?? []))].sort();
---

<BaseLayout title="/namespace/writing — Jacob McNeilly" description="Log stream of writing.">
  <main class="explorer">
    <script type="application/json" id="post-data" set:html={JSON.stringify(postData)} />

    <section class="panel query-panel">
      <div class="panel-header">Query Explorer</div>
      <div class="query-builder">
        <div class="input-group">
          <span class="prompt-char">{">"}</span>
          <input type="search" id="search-input" class="query-input" placeholder="Search logs..." autocomplete="off" />
        </div>
        
        {allTags.length > 0 && (
          <div class="labels-filter">
            <span class="labels-title">Filters:</span>
            {allTags.map(tag => (
              <button type="button" class="filter-chip" data-tag={tag}>
                {tag}
              </button>
            ))}
            <button type="button" class="clear-btn" id="clear-filters" hidden>Clear</button>
          </div>
        )}
      </div>
      <div class="query-status">
         <span id="posts-count" class="count-badge">{posts.length} entries</span>
         <div aria-live="polite" class="sr-only" id="filter-status"></div>
      </div>
    </section>

    <div class="posts-grid" id="post-list">
      {posts.map((entry) => (
        <div class="post-item" data-tags={entry.data.tags?.join(',') ?? ''}>
          <PostCard entry={entry} showTagButtons={false} />
        </div>
      ))}
    </div>

    <div class="empty-state" id="empty-state" hidden>No entries match the current query.</div>
  </main>

<script>
import Fuse from 'fuse.js';

document.addEventListener('DOMContentLoaded', () => {
  // --- Data ---
  const raw = document.getElementById('post-data')?.textContent ?? '[]';
  const postData: { id: string; title: string; tags: string[]; description: string }[] = JSON.parse(raw);

  const fuse = new Fuse(postData, {
    keys: ['title', 'tags', 'description'],
    ignoreLocation: true,
    threshold: 0.3,
    includeScore: false,
  });

  // --- DOM refs ---
  const searchInput  = document.getElementById('search-input') as HTMLInputElement | null;
  const clearBtn     = document.getElementById('clear-filters') as HTMLButtonElement | null;
  const emptyState   = document.getElementById('empty-state') as HTMLParagraphElement | null;
  const filterStatus = document.getElementById('filter-status') as HTMLDivElement | null;
  const countEl      = document.getElementById('posts-count') as HTMLParagraphElement | null;
  const postEntries  = Array.from(document.querySelectorAll<HTMLElement>('.post-item'));
  const filterChips  = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter-chip'));

  // --- State ---
  let activeTags  = new Set<string>();
  let searchQuery = '';

  // --- Core filter ---
  function applyFilters() {
    let searchMatchIds: Set<string> | null = null;
    if (searchQuery.trim() !== '') {
      const results = fuse.search(searchQuery.trim());
      searchMatchIds = new Set(results.map(r => r.item.id));
    }

    let visibleCount = 0;
    postEntries.forEach(entry => {
      const link   = entry.querySelector('a');
      const cardId = link?.getAttribute('href')?.replace(/^\/posts\//, '').replace(/\/$/, '') ?? '';
      const cardTagsRaw = entry.getAttribute('data-tags') ?? '';
      const cardTags    = cardTagsRaw ? cardTagsRaw.split(',') : [];

      const matchesSearch = searchMatchIds === null || searchMatchIds.has(cardId);
      const matchesTags   = activeTags.size === 0 || [...activeTags].every(t => cardTags.includes(t));
      const visible       = matchesSearch && matchesTags;

      entry.style.display = visible ? '' : 'none';

      // Also hide the adjacent tag-button list if present (next sibling)
      const tagButtons = entry.querySelector('.post-entry__tag-buttons');
      if (tagButtons) {
        (tagButtons as HTMLElement).style.display = visible ? '' : 'none';
      }

      if (visible) visibleCount++;
    });

    // Update count
    if (countEl) {
      countEl.textContent = `${visibleCount} post${visibleCount !== 1 ? 's' : ''}`;
    }

    // Empty state
    if (emptyState) {
      if (visibleCount === 0) {
        const hasSearch = searchQuery.trim() !== '';
        const hasTags   = activeTags.size > 0;
        if (hasSearch && hasTags) {
          emptyState.textContent = `No posts match "${searchQuery.trim()}" with the selected tags.`;
        } else if (hasSearch) {
          emptyState.textContent = `No posts match "${searchQuery.trim()}".`;
        } else if (activeTags.size === 1) {
          emptyState.textContent = `No posts tagged "${[...activeTags][0]}".`;
        } else {
          emptyState.textContent = `No posts match all selected tags.`;
        }
        emptyState.hidden = false;
      } else {
        emptyState.hidden = true;
      }
    }

    // Aria live
    if (filterStatus) {
      filterStatus.textContent = `${visibleCount} post${visibleCount !== 1 ? 's' : ''} shown`;
    }

    // Clear button visibility
    const hasActiveFilters = activeTags.size > 0 || searchQuery.trim() !== '';
    if (clearBtn) clearBtn.hidden = !hasActiveFilters;
  }

  // --- Sync all PostCard tag-button states ---
  function syncTagBtns() {
    document.querySelectorAll<HTMLButtonElement>('.tag-btn[data-tag]').forEach(btn => {
      const tag = btn.getAttribute('data-tag') ?? '';
      const isActive = activeTags.has(tag);
      btn.setAttribute('aria-pressed', String(isActive));
      btn.classList.toggle('tag-btn--active', isActive);
    });
  }

  // --- Sync filter bar chip states ---
  function syncFilterChips() {
    filterChips.forEach(chip => {
      const tag = chip.getAttribute('data-tag') ?? '';
      const isActive = activeTags.has(tag);
      chip.setAttribute('aria-pressed', String(isActive));
      chip.classList.toggle('filter-chip--active', isActive);
    });
  }

  // --- Toggle tag ---
  function toggleTag(tag: string) {
    if (activeTags.has(tag)) {
      activeTags.delete(tag);
    } else {
      activeTags.add(tag);
    }
    syncFilterChips();
    syncTagBtns();
    applyFilters();
  }

  // --- Events ---
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    applyFilters();
  });

  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const tag = chip.getAttribute('data-tag') ?? '';
      if (tag) toggleTag(tag);
    });
  });

  // Delegated click for PostCard tag buttons
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.tag-btn[data-tag]');
    if (btn) {
      const tag = btn.getAttribute('data-tag') ?? '';
      if (tag) toggleTag(tag);
    }
  });

  clearBtn?.addEventListener('click', () => {
    activeTags.clear();
    searchQuery = '';
    if (searchInput) searchInput.value = '';
    syncFilterChips();
    syncTagBtns();
    applyFilters();
  });
});
</script>

<style>
  .explorer {
    max-width: var(--container-max); 
    margin: 0 auto; 
    padding: var(--space-4) var(--gutter); 
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .panel {
    background: var(--color-panel);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-4);
  }

  .panel-header {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ink-light);
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
  }

  .query-builder {
    display: flex; flex-direction: column; gap: var(--space-3);
  }

  .input-group {
    display: flex; align-items: center; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 3px; padding: 0 var(--space-3);
  }

  .prompt-char {
    font-family: var(--font-mono); color: var(--color-success); font-weight: bold; margin-right: var(--space-2);
  }

  .query-input {
    flex-grow: 1; padding: var(--space-3) 0; background: transparent; border: none; color: var(--color-ink); font-family: var(--font-mono); font-size: var(--text-sm); outline: none;
  }
  .query-input::placeholder { color: var(--color-ink-light); }

  .labels-filter {
    display: flex; flex-wrap: wrap; gap: var(--space-2); align-items: center;
  }

  .labels-title {
    font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-ink-light);
  }

  .filter-chip {
    font-family: var(--font-mono); font-size: 0.7rem; background: var(--color-bg); border: 1px dashed var(--color-border); color: var(--color-ink-mid); padding: 2px 6px; border-radius: 3px; cursor: pointer; transition: all 0.15s;
  }

  .filter-chip:hover {
    border-color: var(--color-accent); color: var(--color-accent);
  }

  .filter-chip--active, .filter-chip[aria-pressed="true"] {
    background: var(--color-accent-tint); border-color: var(--color-accent); border-style: solid; color: var(--color-accent);
  }

  .clear-btn {
    font-family: var(--font-mono); font-size: 0.7rem; background: transparent; border: none; color: var(--color-danger); cursor: pointer; text-decoration: underline;
  }

  .query-status {
    margin-top: var(--space-4); border-top: 1px solid var(--color-border); padding-top: var(--space-3);
  }

  .count-badge {
    font-family: var(--font-mono); font-size: var(--text-xs); background: var(--color-bg); padding: 2px 6px; border-radius: 3px; border: 1px solid var(--color-border); color: var(--color-ink-light);
  }

  .posts-grid { 
    display: grid; grid-template-columns: 1fr; gap: var(--space-3); 
  }
  @media (min-width: 768px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .posts-grid { grid-template-columns: repeat(3, 1fr); } }

  .empty-state {
    font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-warning); background: var(--color-panel); padding: var(--space-4); border: 1px dashed var(--color-warning); border-radius: 4px;
  }
</style>
</BaseLayout>