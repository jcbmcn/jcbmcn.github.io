---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const posts = allPosts.sort((a, b) => {
  const aDate = a.data.date?.getTime() ?? 0;
  const bDate = b.data.date?.getTime() ?? 0;
  return bDate - aDate;
});

// Serialize post data for client-side Fuse.js
const postData = posts.map(entry => ({
  id: entry.id,
  title: entry.data.title,
  tags: entry.data.tags ?? [],
  description: entry.data.description ?? '',
}));

// Collect unique tags for filter bar (sorted alphabetically)
const allTags = [...new Set(posts.flatMap(p => p.data.tags ?? []))].sort();
---

<BaseLayout title="Posts — Jacob McNeilly" description="All posts on SRE, Kubernetes, and software engineering.">
  <main class="page-container">
    <script type="application/json" id="post-data" set:text={JSON.stringify(postData)} />

    <header class="listing-header">
      <a href="/" class="back-link">← Home</a>
      <h1 class="listing-title">Posts</h1>
      <p class="listing-count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
    </header>

    <!-- Search + Tag filter controls -->
    <div class="listing-controls">
      <input
        type="search"
        id="search-input"
        class="search-input"
        placeholder="Search posts…"
        aria-label="Search posts"
        autocomplete="off"
      />
      <div class="filter-bar" role="group" aria-label="Filter by tag">
        {allTags.map(tag => (
          <button type="button" class="filter-chip" data-tag={tag} aria-pressed="false">
            {tag}
          </button>
        ))}
        <button type="button" class="clear-filters" id="clear-filters" aria-label="Clear all filters" hidden>
          × Clear filters
        </button>
      </div>
    </div>
    <!-- Aria live region for screen readers -->
    <div aria-live="polite" aria-atomic="true" class="sr-only" id="filter-status"></div>

    <div class="post-list">
      {posts.map((entry) => (
        <PostCard entry={entry} />
      ))}
    </div>

    <p class="empty-state" id="empty-state" hidden></p>
  </main>
</BaseLayout>

<script>
import Fuse from 'fuse.js';

document.addEventListener('DOMContentLoaded', () => {
  // --- Data ---
  const raw = document.getElementById('post-data')?.textContent ?? '[]';
  const postData: { id: string; title: string; tags: string[]; description: string }[] = JSON.parse(raw);

  const fuse = new Fuse(postData, {
    keys: ['title', 'tags', 'description'],
    ignoreLocation: true,
    threshold: 0.3,
    includeScore: false,
  });

  // --- DOM refs ---
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement | null;
  const emptyState = document.getElementById('empty-state') as HTMLParagraphElement | null;
  const filterStatus = document.getElementById('filter-status') as HTMLDivElement | null;
  const countEl = document.querySelector('.listing-count') as HTMLParagraphElement | null;
  const postCards = Array.from(document.querySelectorAll<HTMLElement>('[data-tags]'));
  const filterChips = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter-chip'));

  // --- State ---
  let activeTags = new Set<string>();
  let searchQuery = '';

  // --- Core filter function ---
  function applyFilters() {
    // 1. Determine IDs matching full-text search
    let searchMatchIds: Set<string> | null = null;
    if (searchQuery.trim() !== '') {
      const results = fuse.search(searchQuery.trim());
      searchMatchIds = new Set(results.map(r => r.item.id));
    }

    // 2. Show/hide cards
    let visibleCount = 0;
    postCards.forEach(card => {
      const cardId = card.querySelector('a')?.getAttribute('href')?.replace(/^\/posts\//, '').replace(/\/$/, '') ?? '';
      const cardTagsRaw = card.getAttribute('data-tags') ?? '';
      const cardTags = cardTagsRaw ? cardTagsRaw.split(',') : [];

      // Check search match
      const matchesSearch = searchMatchIds === null || searchMatchIds.has(cardId);

      // Check tag match (AND logic — must match ALL active tags)
      const matchesTags = activeTags.size === 0 || [...activeTags].every(t => cardTags.includes(t));

      const visible = matchesSearch && matchesTags;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    // 3. Update post count
    if (countEl) {
      countEl.textContent = `${visibleCount} post${visibleCount !== 1 ? 's' : ''}`;
    }

    // 4. Show/hide empty state with correct copy per UI-SPEC copywriting contract
    if (emptyState) {
      if (visibleCount === 0) {
        const hasSearch = searchQuery.trim() !== '';
        const hasTags = activeTags.size > 0;
        if (hasSearch && hasTags) {
          emptyState.textContent = `No posts match "${searchQuery.trim()}" with the selected tags.`;
        } else if (hasSearch) {
          emptyState.textContent = `No posts match "${searchQuery.trim()}".`;
        } else if (activeTags.size === 1) {
          emptyState.textContent = `No posts tagged "${[...activeTags][0]}".`;
        } else {
          emptyState.textContent = `No posts match all selected tags.`;
        }
        emptyState.hidden = false;
      } else {
        emptyState.hidden = true;
      }
    }

    // 5. Update aria-live region
    if (filterStatus) {
      filterStatus.textContent = `${visibleCount} post${visibleCount !== 1 ? 's' : ''} shown`;
    }

    // 6. Show/hide clear button
    const hasActiveFilters = activeTags.size > 0 || searchQuery.trim() !== '';
    if (clearBtn) clearBtn.hidden = !hasActiveFilters;
  }

  // --- Sync PostCard tag chip active states ---
  function syncPostCardChips() {
    document.querySelectorAll<HTMLButtonElement>('.post-card__tag[data-tag]').forEach(btn => {
      const tag = btn.getAttribute('data-tag') ?? '';
      const isActive = activeTags.has(tag);
      btn.setAttribute('aria-pressed', String(isActive));
      btn.classList.toggle('post-card__tag--active', isActive);
    });
  }

  // --- Sync filter bar chip active states ---
  function syncFilterChips() {
    filterChips.forEach(chip => {
      const tag = chip.getAttribute('data-tag') ?? '';
      const isActive = activeTags.has(tag);
      chip.setAttribute('aria-pressed', String(isActive));
      chip.classList.toggle('filter-chip--active', isActive);
    });
  }

  // --- Toggle tag helper ---
  function toggleTag(tag: string) {
    if (activeTags.has(tag)) {
      activeTags.delete(tag);
    } else {
      activeTags.add(tag);
    }
    syncFilterChips();
    syncPostCardChips();
    applyFilters();
  }

  // --- Event: search input ---
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    applyFilters();
  });

  // --- Event: filter bar chip clicks ---
  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      const tag = chip.getAttribute('data-tag') ?? '';
      if (tag) toggleTag(tag);
    });
  });

  // --- Event: PostCard tag chip clicks (delegated) ---
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.post-card__tag[data-tag]');
    if (btn) {
      const tag = btn.getAttribute('data-tag') ?? '';
      if (tag) toggleTag(tag);
    }
  });

  // --- Event: Clear filters ---
  clearBtn?.addEventListener('click', () => {
    activeTags.clear();
    searchQuery = '';
    if (searchInput) searchInput.value = '';
    syncFilterChips();
    syncPostCardChips();
    applyFilters();
  });
});
</script>

<style>
  .page-container {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .listing-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .listing-title {
    margin: 0 0 0.25rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .listing-count {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Controls block */
  .listing-controls {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }

  /* Search input */
  .search-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: var(--font-sans, inherit);
    color: var(--color-text-primary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    outline: none;
    box-sizing: border-box;
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-input:focus {
    border: 2px solid var(--color-accent);
  }

  /* Tag filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
  }

  /* Filter chips (mirror .post-card__tag exactly) */
  .filter-chip {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    line-height: 1;
  }

  .filter-chip:hover {
    background: var(--color-accent);
    color: white;
  }

  .filter-chip--active {
    background: var(--color-accent);
    color: white;
  }

  /* Clear filters button */
  .clear-filters {
    font-size: 0.875rem;
    color: var(--color-accent);
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    padding: 0 0.25rem;
    text-decoration: none;
  }

  .clear-filters:hover {
    text-decoration: underline;
  }

  /* Empty state */
  .empty-state {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    padding: 1.5rem 0;
    margin: 0;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
