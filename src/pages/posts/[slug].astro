---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, date, tags = [], featuredImage, images } = entry.data;
const image = featuredImage ?? images?.[0] ?? undefined;

const formattedDate = date
  ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<BaseLayout title={`${title} — Jacob McNeilly`} description={title}>
  <main class="post-page">

    <!-- Post header: title, meta -->
    <article>
      <header class="post-header">
        <a href="/posts/" class="back-link">← Writing</a>

        <h1 class="post-title">{title}</h1>

        <div class="post-meta">
          {formattedDate && (
            <time class="post-meta__date" datetime={date?.toISOString()}>
              {formattedDate}
            </time>
          )}
          {tags.length > 0 && (
            <ul class="post-meta__tags" aria-label="Tags">
              {tags.map((tag) => (
                <li class="post-meta__tag">{tag}</li>
              ))}
            </ul>
          )}
        </div>
      </header>

      <!-- Featured image: full-width within the container -->
      {image && (
        <figure class="post-image">
          <img
            src={image}
            alt={title}
            width="1200"
            height="630"
            class="post-image__img"
            loading="eager"
            decoding="async"
          />
        </figure>
      )}

      <!-- Body: @tailwindcss/typography prose -->
      <div class="prose post-body">
        <Content />
      </div>

      <!-- Post footer -->
      <footer class="post-footer">
        <a href="/posts/" class="back-link back-link--footer">← Back to writing</a>
      </footer>
    </article>
  </main>
</BaseLayout>

<!-- Mermaid diagram rendering -->
<script type="module">
  async function renderMermaid() {
    const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"]');
    if (mermaidBlocks.length === 0) return;

    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    const mermaid = (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;

    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'neutral',
    });

    // Decode HTML entities via textarea round-trip (handles &#x3C; → <, &#x26; → &, etc.)
    // Called twice because Shiki double-encodes some characters (e.g. &#x26;amp; → &amp; → &)
    function decodeEntities(str) {
      const txt = document.createElement('textarea');
      txt.innerHTML = str;
      const once = txt.value;
      txt.innerHTML = once;
      return txt.value;
    }

    for (const pre of mermaidBlocks) {
      const code = pre.querySelector('code');
      if (!code) continue;

      // Get the raw Shiki-processed HTML, strip every HTML tag (spans, code, br, b, etc.),
      // then decode entities. Newlines between .line spans are preserved by the tag stripping.
      const rawHtml = code.innerHTML;
      // Replace <br> with newline before stripping so line breaks inside node labels survive
      const withNewlines = rawHtml.replace(/<br\s*\/?>/gi, '\n');
      // Strip all remaining HTML tags
      const stripped = withNewlines.replace(/<[^>]+>/g, '');
      // Double-decode entities
      const definition = decodeEntities(stripped).trim();

      const container = document.createElement('div');
      container.className = 'mermaid-diagram';
      pre.replaceWith(container);

      try {
        const id = `mermaid-${Math.random().toString(36).slice(2)}`;
        const { svg } = await mermaid.render(id, definition);
        container.innerHTML = svg;
      } catch (e) {
        container.innerHTML = `<pre class="mermaid-error"><code>${definition}</code></pre>`;
        console.error('Mermaid render error:', e);
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderMermaid);
  } else {
    renderMermaid();
  }
</script>

<!-- Copy-to-clipboard: runs after all <pre> elements are in the DOM -->
<script>
  function addCopyButtons() {
    document.querySelectorAll('pre').forEach((pre) => {
      // Skip mermaid blocks — they get replaced entirely
      if (pre.getAttribute('data-language') === 'mermaid') return;
      if (pre.querySelector('.copy-btn')) return;

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.textContent = 'Copy';

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = 'Copied';
          btn.classList.add('copy-btn--copied');
          setTimeout(() => {
            btn.textContent = 'Copy';
            btn.classList.remove('copy-btn--copied');
          }, 2000);
        } catch {
          btn.textContent = 'Failed';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        }
      });

      pre.style.position = 'relative';
      pre.appendChild(btn);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', addCopyButtons);
  } else {
    addCopyButtons();
  }
</script>

<style>
  /* ============================================================
     PAGE CONTAINER
     ============================================================ */
  .post-page {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--gutter) clamp(4rem, 10vw, 8rem);
  }

  /* ============================================================
     POST HEADER
     ============================================================ */
  .back-link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-ink-light);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.12s ease;
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
  }

  .back-link:hover {
    color: var(--color-accent-text);
  }

  .post-header {
    display: flex;
    flex-direction: column;
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-5);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.8rem);
    font-weight: 800;
    font-style: italic;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: var(--space-4) 0 var(--space-3);
    max-width: 32ch;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }

  .post-meta__date {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-light);
    font-variant-numeric: tabular-nums;
  }

  .post-meta__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .post-meta__tag {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-accent-text);
    background: var(--color-accent-tint);
    border: 1px solid oklch(66% 0.160 62 / 0.25);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    line-height: 1.6;
  }

  /* ============================================================
     FEATURED IMAGE
     ============================================================ */
  .post-image {
    margin: 0 0 var(--space-6);
    border-radius: 3px;
    overflow: hidden;
  }

  .post-image__img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 480px;
    object-fit: cover;
  }

  /* ============================================================
     POST BODY (prose)
     ============================================================ */
  .post-body {
    /* Let prose fill the post-page container width */
    max-width: none;
  }

  /* Pre blocks: override padding to make room for copy button */
  .post-body :global(pre) {
    padding-top: 2.5rem !important;
  }

  /* ============================================================
     COPY BUTTON
     ============================================================ */
  :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.6rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: oklch(70% 0.008 72);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 2px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease, background-color 0.15s ease, color 0.15s ease;
    line-height: 1.6;
  }

  :global(pre:hover .copy-btn),
  :global(.copy-btn:focus-visible) {
    opacity: 1;
  }

  :global(.copy-btn--copied) {
    color: oklch(78% 0.12 145);
    border-color: oklch(78% 0.12 145 / 0.3);
    background: oklch(78% 0.12 145 / 0.08);
    opacity: 1;
  }

  /* ============================================================
     POST FOOTER
     ============================================================ */
  .post-footer {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border-soft);
  }

  .back-link--footer {
    margin-top: 0;
  }

  /* ============================================================
     MERMAID DIAGRAMS
     ============================================================ */
  :global(.mermaid-diagram) {
    margin: var(--space-5) 0;
    overflow-x: auto;
    text-align: center;
  }

  :global(.mermaid-diagram svg) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  :global(.mermaid-error) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-ink-mid);
    overflow-x: auto;
  }
</style>
