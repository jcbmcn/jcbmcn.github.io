---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, date, tags = [], featuredImage, images } = entry.data;
const image = featuredImage ?? images?.[0] ?? undefined;

const formattedDate = date
  ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<BaseLayout title={`${title} | jcbmcn`} description={title}>
  <main class="detail-dashboard">
    <div class="top-nav">
      <a href="/posts/" class="cmd-link">cd ..</a>
    </div>

    <article class="panel doc-panel">
      <header class="doc-header">
        <div class="meta-row">
          <span class="status-indicator">
            <span class="status-dot"></span> <span class="status-text">HEALTHY</span>
          </span>
          {formattedDate && (
             <span class="sys-time">uptime: {formattedDate}</span>
          )}
        </div>
        
        <h1 class="doc-title">{title}</h1>

        {tags.length > 0 && (
          <div class="k8s-labels">
            {tags.map((tag) => (
              <span class="k8s-label"><span class="label-key">tag</span>:<span class="label-val">{tag}</span></span>
            ))}
          </div>
        )}
      </header>

      {/* Featured image logic remains same */}
      {image && (
        <figure class="post-image">
          <img src={image} alt={title} width="1200" height="630" class="post-image__img" loading="eager" decoding="async" />
        </figure>
      )}

      <div class="prose post-body">
        <Content />
      </div>

      <footer class="doc-footer">
        <span class="eof-marker">EOF</span>
      </footer>
    </article>
  </main>
</BaseLayout>

<!-- Mermaid diagram rendering -->
<script type="module">
  async function renderMermaid() {
    const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"]');
    if (mermaidBlocks.length === 0) return;

    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    const mermaid = (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;

    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'neutral',
    });

    // Decode HTML entities via textarea round-trip (handles &#x3C; → <, &#x26; → &, etc.)
    // Called twice because Shiki double-encodes some characters (e.g. &#x26;amp; → &amp; → &)
    function decodeEntities(str) {
      const txt = document.createElement('textarea');
      txt.innerHTML = str;
      const once = txt.value;
      txt.innerHTML = once;
      return txt.value;
    }

    for (const pre of mermaidBlocks) {
      const code = pre.querySelector('code');
      if (!code) continue;

      // Get the raw Shiki-processed HTML, strip every HTML tag (spans, code, br, b, etc.),
      // then decode entities. Newlines between .line spans are preserved by the tag stripping.
      const rawHtml = code.innerHTML;
      // Replace <br> with newline before stripping so line breaks inside node labels survive
      const withNewlines = rawHtml.replace(/<br\s*\/?>/gi, '\n');
      // Strip all remaining HTML tags
      const stripped = withNewlines.replace(/<[^>]+>/g, '');
      // Double-decode entities
      const definition = decodeEntities(stripped).trim();

      const container = document.createElement('div');
      container.className = 'mermaid-diagram';
      pre.replaceWith(container);

      try {
        const id = `mermaid-${Math.random().toString(36).slice(2)}`;
        const { svg } = await mermaid.render(id, definition);
        container.innerHTML = svg;
      } catch (e) {
        container.innerHTML = `<pre class="mermaid-error"><code>${definition}</code></pre>`;
        console.error('Mermaid render error:', e);
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderMermaid);
  } else {
    renderMermaid();
  }
</script>

<!-- Copy-to-clipboard: runs after all <pre> elements are in the DOM -->
<script>
  function addCopyButtons() {
    document.querySelectorAll('pre').forEach((pre) => {
      // Skip mermaid blocks — they get replaced entirely
      if (pre.getAttribute('data-language') === 'mermaid') return;
      if (pre.querySelector('.copy-btn')) return;

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.textContent = 'Copy';

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = 'Copied';
          btn.classList.add('copy-btn--copied');
          setTimeout(() => {
            btn.textContent = 'Copy';
            btn.classList.remove('copy-btn--copied');
          }, 2000);
        } catch {
          btn.textContent = 'Failed';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        }
      });

      pre.style.position = 'relative';
      pre.appendChild(btn);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', addCopyButtons);
  } else {
    addCopyButtons();
  }
</script>

<style>
  .detail-dashboard {
    max-width: var(--container-max); 
    margin: 0 auto; 
    padding: var(--space-4) var(--gutter); 
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .top-nav { margin-bottom: var(--space-2); }
  .cmd-link {
    font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-ink-light); text-decoration: none;
  }
  .cmd-link:hover { color: var(--color-accent); text-decoration: underline; }

  .panel {
    background: var(--color-panel);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: clamp(var(--space-4), 5vw, var(--space-7));
  }

  .doc-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .meta-row {
    display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-ink-light); margin-bottom: var(--space-4);
  }

  .status-indicator { display: flex; align-items: center; gap: 6px; }
  .status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-success); }
  .status-text { color: var(--color-success); font-weight: bold;}

  .doc-title {
    font-size: clamp(2rem, 4vw, 3rem); font-weight: 600; color: var(--color-ink); line-height: 1.2; margin-bottom: var(--space-4);
  }

  .k8s-labels { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .k8s-label {
    font-family: var(--font-mono); font-size: 0.75rem; background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 3px; padding: 2px 8px; display: inline-flex;
  }
  .label-key { color: var(--color-accent); padding-right: 4px; }
  .label-val { color: var(--color-warning); padding-left: 4px; }

  .post-image { margin: 0 0 var(--space-6); border: 1px solid var(--color-border); border-radius: 4px; overflow: hidden; }
  .post-image__img { width: 100%; height: auto; display: block; max-height: 400px; object-fit: cover; }

  .doc-footer {
    margin-top: var(--space-7); border-top: 1px dashed var(--color-border); padding-top: var(--space-4); text-align: center;
  }
  .eof-marker {
    font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-ink-light);
  }

  .post-body :global(pre) {
    padding-top: 2.5rem !important;
  }

  /* Retain copy button and mermaid styles from previous implementation */
  :global(.copy-btn) {
    position: absolute; top: 0.5rem; right: 0.5rem; padding: 0.2rem 0.6rem; font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-ink-light); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: 3px; cursor: pointer; opacity: 0; transition: all 0.15s;
  }
  :global(pre:hover .copy-btn), :global(.copy-btn:focus-visible) { opacity: 1; }
  :global(.copy-btn:hover) { border-color: var(--color-accent); color: var(--color-accent); }
  :global(.copy-btn--copied) { color: var(--color-success); border-color: var(--color-success); }

  /* ============================================================
     MERMAID DIAGRAMS
     ============================================================ */
  :global(.mermaid-diagram) {
    margin: var(--space-5) 0;
    overflow-x: auto;
    text-align: center;
  }

  :global(.mermaid-diagram svg) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
  }

  :global(.mermaid-error) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-ink-mid);
    overflow-x: auto;
  }
</style>