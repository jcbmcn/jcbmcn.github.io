---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, date, tags = [], featuredImage, images } = entry.data;
const image = featuredImage ?? images?.[0] ?? undefined;

const formattedDate = date
  ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<BaseLayout title={`${title} — Jacob McNeilly`} description={title}>
  <main class="page-container">
    <!-- Post header -->
    <article>
      <header class="post-header">
        <a href="/posts/" class="back-link">← All posts</a>
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          {formattedDate && (
            <time datetime={date?.toISOString()}>{formattedDate}</time>
          )}
          {tags.length > 0 && (
            <ul class="post-tags">
              {tags.map((tag) => (
                <li class="post-tag">{tag}</li>
              ))}
            </ul>
          )}
        </div>
      </header>

      <!-- Featured image -->
      {image && (
        <div class="post-featured-image">
          <img
            src={image}
            alt={title}
            width="800"
            height="450"
            class="post-featured-image__img"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      <!-- Post body — prose class applies @tailwindcss/typography styles -->
      <div class="prose post-body">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<!-- Copy-to-clipboard: injected after render so all <pre> elements exist in DOM -->
<script>
  function addCopyButtons() {
    const codeBlocks = document.querySelectorAll('pre');

    codeBlocks.forEach((pre) => {
      // Avoid double-adding if script runs twice
      if (pre.querySelector('.copy-btn')) return;

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.textContent = 'Copy';

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
          btn.textContent = 'Copied!';
          btn.classList.add('copy-btn--copied');
          setTimeout(() => {
            btn.textContent = 'Copy';
            btn.classList.remove('copy-btn--copied');
          }, 2000);
        } catch {
          btn.textContent = 'Failed';
          setTimeout(() => {
            btn.textContent = 'Copy';
          }, 2000);
        }
      });

      // Position button relative to pre
      pre.style.position = 'relative';
      pre.appendChild(btn);
    });
  }

  // Run after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', addCopyButtons);
  } else {
    addCopyButtons();
  }
</script>

<style>
  .page-container {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .post-title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.25;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .post-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .post-tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-accent);
    background: var(--color-accent-subtle);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }

  .post-featured-image {
    margin-bottom: 2rem;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .post-featured-image__img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 400px;
    object-fit: cover;
  }

  /* Copy button — positioned inside each <pre> block */
  :global(.copy-btn) {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--font-sans);
    color: #cdd6f4;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.25rem;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease, background-color 0.15s ease;
    line-height: 1.4;
  }

  :global(pre:hover .copy-btn),
  :global(.copy-btn:focus) {
    opacity: 1;
  }

  :global(.copy-btn--copied) {
    color: #a6e3a1;
    border-color: rgba(166, 227, 161, 0.3);
    background: rgba(166, 227, 161, 0.1);
    opacity: 1;
  }

  /* Prose overrides — tweak @tailwindcss/typography defaults to use our tokens */
  .post-body :global(a) {
    color: var(--color-accent);
  }

  .post-body :global(a:hover) {
    color: var(--color-accent-hover);
  }

  /* Ensure pre blocks have enough top padding to accommodate the copy button */
  .post-body :global(pre) {
    padding-top: 2.5rem;
  }
</style>
